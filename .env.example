# Copy this to .env and fill in the values

# Backend auth — generate with: openssl rand -hex 32
JWT_SECRET=change-me-to-a-long-random-string
INTERNAL_API_KEY=another-random-secret

# AI Poller auth — uses INTERNAL_API_KEY above, no JWT needed
# WORKPLANNER_JWT is not required for local setup

# Claude Proxy key (set in claude-proxy/.env too). Leave empty in dev —
# the proxy skips the auth check when CLAUDE_PROXY_KEY is unset.
CLAUDE_PROXY_KEY=

# ANTHROPIC_API_KEY is only required for the legacy algorithm dispatch.
# Chat-mode (ENABLE_CHAT_HANDLER=true, the default in docker-compose)
# routes through claude-proxy which uses your claude.ai subscription,
# so no API key needed.
ANTHROPIC_API_KEY=

# Agent limits
MAX_GLOBAL_AGENTS=8
MAX_ORCHESTRATORS=4
MAX_TURNS_PER_RUN=40
DEBATE_AGENTS=2
DEBATE_MAX_ROUNDS=10
POLL_INTERVAL_SECONDS=60

# ChromaDB
CHROMADB_COLLECTION=workplanner_knowledge
