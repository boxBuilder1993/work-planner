# WorkPlanner backend URL
WORKPLANNER_API_URL=http://localhost:8080

# JWT token (get from browser localStorage after signing in)
WORKPLANNER_JWT=eyJhbGciOiJIUzI1NiIs...

# Anthropic API key for Claude Agent SDK
ANTHROPIC_API_KEY=sk-ant-...

# Poll interval in seconds (default: 300 = 5 minutes)
POLL_INTERVAL_SECONDS=300

# Dispatch mode. When true, the chat-mention handler runs and legacy
# algorithm dispatch (SDLC / orchestrated / decompose / etc.) is fully
# bypassed. When false (default), legacy dispatch runs as before.
# See docs/CHAT_DESIGN.md. Set to `true` once chat_handler is wired up
# (or earlier to silence the legacy poller entirely).
ENABLE_CHAT_HANDLER=false

# Archivist: review every new comment for knowledge-base upkeep (create /
# update / nothing on the company knowledge cards). Requires
# ENABLE_CHAT_HANDLER=true. ARCHIVIST_BATCH caps comments reviewed per cycle.
# See docs/KNOWLEDGE_CARDS_DESIGN.md.
ENABLE_ARCHIVIST=false
ARCHIVIST_BATCH=10

# Agent limits
MAX_GLOBAL_AGENTS=20
MAX_TASKS_PER_AGENT=3
MAX_TURNS_PER_RUN=10

# Workspace isolation
REPO_PATH=/path/to/repo
WORKTREE_BASE=.claude/worktrees
MAIN_BRANCH=main
